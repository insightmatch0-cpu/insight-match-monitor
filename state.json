  "ar": {
   "home": "دروغيدا يونايتد",
   "away": "لوكان يونايتد",
   "league": "كأس أيرلندا (أيرلندا)"
  },
  "pulse": "قراءة مركزة: دروغيدا يونايتد، فريق الدرجة الممتازة، يسيطر تماماً على مواجهة كأس غير متكافئة أمام لوكان يونايتد الهاوي. هدف مبكر من إم. دويل في الدقيقة 3 ثم هدف ثانٍ قبل نهاية الشوط يعكسان ضغطاً مستمراً وأفضلية فنية واضحة، ولوكان بالكاد يخرج من نصف ملعبه.\nالسيناريو: الهدف القادم لدروغيدا يونايتد مع ترشيح إم. دويل لإضافة هدف ثانٍ شخصي بعد افتتاحه التسجيل (70%) — الشوط الثاني أغزر أهدافاً مع تراجع لياقة الفريق الهاوي وفوز دروغيدا بهامش 3 أهداف أو أكثر (60%) — كلا الفريقين يسجلان مستبعد نسبياً مع سيطرة دفاعية كاملة، والأرجح شباك نظيفة لدروغيدا (65%).\nالتوقع: دروغيدا يونايتد — ثقة 93%"
 },
 "1548965": {
